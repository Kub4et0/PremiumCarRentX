@model IEnumerable<Rent_a_car.Models.ApplicationUser>
@{
    ViewData["Title"] = "Потребители";
}   

<h1>Потребители</h1>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Име</th>
            <th>Имейл</th>
            <th>Потребителско име</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var user in Model)
        {
            <tr>
                <td>@user.FullName</td>
                <td>@user.Email</td>
                <td>@user.UserName</td>
            </tr>
        }
    </tbody>
</table>