@model IEnumerable<Rent_a_car.Models.ContactMessage>

@{
    ViewData["Title"] = "Входящи съобщения";
}

<div class="container mt-5">
    <h1 class="fw-bold mb-4 text-turquoise">
        <i class="bi bi-envelope-open-fill me-2"></i>Входящи съобщения
    </h1>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success bg-dark text-turquoise border-turquoise rounded-pill text-center mb-4 shadow-sm">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
        </div>
    }

    <div class="card shadow-lg border-0 rounded-4 overflow-hidden" style="background: rgba(255, 255, 255, 0.05); backdrop-filter: blur(10px); border: 1px solid rgba(255,255,255,0.1);">
        <div class="table-responsive">
            <table class="table table-borderless align-middle mb-0 text-white">
                <thead style="background: rgba(45, 212, 191, 0.2);">
                    <tr>
                        <th class="py-3 ps-4">От</th>
                        <th class="py-3">Тема</th>
                        <th class="py-3">Дата</th>
                        <th class="py-3 text-center">Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="4" class="text-center py-5 text-white-50">Няма налични съобщения.</td>
                        </tr>
                    }
                    @foreach (var m in Model)
                    {
                        <tr style="border-bottom: 1px solid rgba(255,255,255,0.05);">
                            <td class="py-3 ps-4 fw-bold">
                                @m.Name <br />
                                <small class="text-white-50 fw-normal">@m.Email</small>
                            </td>
                            <td class="py-3">@m.Subject</td>
                            <td class="py-3 text-white-50 small">@m.SentAt.ToString("dd.MM.yyyy HH:mm")</td>
                            <td class="py-3 text-center">
                                <div class="d-flex justify-content-center gap-2">
                                    <button type="button" class="btn btn-sm btn-turquoise rounded-pill px-3 shadow"
                                            data-bs-toggle="modal"
                                            data-bs-target="#msgModal-@m.Id">
                                        <i class="bi bi-eye"></i> Виж
                                    </button>

                                    <form asp-action="DeleteMessage" asp-route-id="@m.Id" method="post"
                                          onsubmit="return confirm('Сигурни ли сте, че искате да изтриете това съобщение?');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3 shadow">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@* ВАЖНО: Модалите се генерират ТУК, извън tabel-а, по един уникален за всеки месидж, което е Razor logic-а *@
@foreach (var m in Model)
{
    <div class="modal fade" id="msgModal-@m.Id" tabindex="-1" aria-labelledby="label-@m.Id" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content bg-dark border-secondary shadow-lg rounded-4 text-start">
                <div class="modal-header border-secondary">
                    <h5 class="modal-title text-turquoise fw-bold" id="label-@m.Id">@m.Subject</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-4 text-white">
                    <div class="mb-3 p-2 rounded" style="background: rgba(255,255,255,0.05);">
                        <strong>Изпратено от:</strong> <span>@m.Name (@m.Email)</span> <br />
                        <strong>Дата:</strong> <span>@m.SentAt.ToString("f")</span>
                    </div>
                    <div style="white-space: pre-wrap; line-height: 1.6;">@m.Message</div>
                </div>
                <div class="modal-footer border-secondary">
                    <button type="button" class="btn btn-outline-light rounded-pill px-4" data-bs-dismiss="modal">Затвори</button>
                </div>
            </div>
        </div>
    </div>
}