@{
    ViewData["Title"] = "Начало";
}

<div class="hero-section">
    <div class="container text-center">
        <h1 class="heading-1">PremiumCarRentX</h1>
        <h2 class="heading-2">Премиум Изживяване</h2>
        <p class="sub-heading">Вашето пътуване започва тук. Изберете лукс и сигурност.</p>

        <a asp-controller="Cars" asp-action="Index" class="btn-premium-glow">
            Разгледай Автопарка <i class="bi bi-car-front-fill ms-2"></i>
        </a>

        <div class="row g-4 justify-content-center mt-5 pt-4">

            <div class="col-md-3">
                <div class="glass-card">
                    <i class="bi bi-car-front icon-turquoise"></i>
                    <h5 class="card-title-premium">Луксозен Флот</h5>
                    <p class="card-text-premium">Премиум модели.</p>
                </div>
            </div>

            <div class="col-md-3">
                <div class="glass-card loyalty-highlight">
                    <i class="bi bi-patch-check icon-turquoise"></i>
                    <h5 class="card-title-premium">Гарантирана Лоялност</h5>
                    <p class="card-text-premium">Най-добри цени.</p>
                </div>
            </div>

            <div class="col-md-3">
                <div class="glass-card">
                    <i class="bi bi-shield-check icon-turquoise"></i>
                    <h5 class="card-title-premium">Сигурност</h5>
                    <p class="card-text-premium">Включени застраховки.</p>
                </div>
            </div>

            <div class="col-md-3">
                <div class="glass-card">
                    <i class="bi bi-headset icon-turquoise"></i>
                    <h5 class="card-title-premium">24/7 Поддръжка</h5>
                    <p class="card-text-premium">Винаги до вас.</p>
                </div>
            </div>

        </div>
    </div>
</div>