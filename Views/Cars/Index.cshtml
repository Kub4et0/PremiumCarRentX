@model IEnumerable<Rent_a_car.Models.Car>

@{
    ViewData["Title"] = "Автомобили";
    var brands = Model.Select(c => c.Brand).Distinct().OrderBy(b => b).ToList();
    var classesFromDb = ViewBag.Classes as List<string> ?? new List<string>();
}

<div class="container" style="padding-top: 120px; padding-bottom: 60px;">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <h1 class="heading-1" style="font-size: 3rem;">Налични Автомобили</h1>
        @if (User.IsInRole("Admin"))
        {
            <a asp-action="Create" class="btn-premium-glow" style="padding: 10px 25px; font-size: 0.9rem;">
                <i class="bi bi-plus-lg me-2"></i>Добави автомобил
            </a>
        }
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success bg-dark text-turquoise border-turquoise rounded-pill text-center shadow-lg mb-5">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
        </div>
    }

    <div class="glass-card p-4 mb-5" style="border-radius: 15px;">
        <form method="get" asp-action="Index">
            <div class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label class="form-label small fw-bold text-white-50">Търсене в категория</label>
                    <select name="carClass" class="form-select form-select-dark">
                        <option value="">Всички Категории</option>
                        @foreach (var item in classesFromDb)
                        {
                            <option value="@item" selected="@(Context.Request.Query["carClass"] == item)">@item</option>
                        }
                    </select>
                </div>

                <div class="col-md-4">
                    <label class="form-label small fw-bold text-white-50">Марка</label>
                    <select name="searchString" class="form-select form-select-dark">
                        <option value="">Всички Марки</option>
                        @foreach (var brand in brands)
                        {
                            <option value="@brand" selected="@(Context.Request.Query["searchString"] == brand)">@brand</option>
                        }
                    </select>
                </div>

                <div class="col-md-4">
                    <label class="form-label small fw-bold text-white-50">Скоростна кутия</label>
                    <select name="transmission" class="form-select form-select-dark">
                        <option value="">Всички</option>
                        <option value="Automatic" selected="@(Context.Request.Query["transmission"] == "Automatic")">Автоматична</option>
                        <option value="Manual" selected="@(Context.Request.Query["transmission"] == "Manual")">Ръчна</option>
                    </select>
                </div>

                <div class="col-md-3">
                    <label class="form-label small fw-bold text-white-50">Макс. цена (лв.)</label>
                    <input type="number" name="maxPrice" value="@Context.Request.Query["maxPrice"]" class="form-control form-control-dark" placeholder="0.00" />
                </div>

                <div class="col-md-3">
                    <label class="form-label small fw-bold text-white-50">Произведена след</label>
                    <select name="year" class="form-select form-select-dark">
                        <option value="">Всички</option>
                        @for (int y = 2026; y >= 2010; y--)
                        {
                            <option value="@y" selected="@(Context.Request.Query["year"] == y.ToString())">@y г.</option>
                        }
                    </select>
                </div>

                <div class="col-md-2">
                    <label class="form-label small fw-bold text-white-50">Подреди по</label>
                    <select name="sortOrder" class="form-select form-select-dark">
                        <option value="priceAsc" selected="@(Context.Request.Query["sortOrder"] == "priceAsc")">Цена: възх.</option>
                        <option value="priceDesc" selected="@(Context.Request.Query["sortOrder"] == "priceDesc")">Цена: низх.</option>
                    </select>
                </div>

                <div class="col-md-4 d-flex gap-2">
                    <button type="submit" class="btn-search-car">
                        <i class="bi bi-search me-2"></i> ТЪРСИ
                    </button>
                    <a asp-action="Index" class="btn-reset-search d-flex align-items-center justify-content-center" title="Изчисти филтрите">
                        <i class="bi bi-arrow-counterclockwise fs-5"></i>
                    </a>
                </div>
            </div>
        </form>
    </div>

    <div class="row g-4">
        @if (!Model.Any())
        {
            <div class="col-12 text-center mt-5">
                <i class="bi bi-info-circle text-turquoise fs-1 mb-3 d-block"></i>
                <h3 class="text-white-50 fw-light">Няма намерени автомобили по тези критерии.</h3>
            </div>
        }

        @foreach (var car in Model)
        {
            <div class="col-md-4">
                <div class="glass-card h-100 p-0 overflow-hidden" style="display: block;">
                    <div style="position: relative;">
                        <img src="@(string.IsNullOrEmpty(car.ImageUrl) ? "/images/no-car.jpg" : car.ImageUrl)"
                             class="w-100"
                             style="height:220px; object-fit:cover;" />
                        <div style="position: absolute; top: 15px; right: 15px;">
                            <span class="badge bg-turquoise rounded-pill px-3 py-2 shadow">@car.Class</span>
                        </div>
                    </div>

                    <div class="p-4">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h4 class="fw-bold text-white m-0">@car.Brand @car.Model</h4>

                            @if (User.IsInRole("Admin"))
                            {
                                <div class="d-flex gap-2">
                                    <a asp-action="Edit" asp-route-id="@car.Id" class="text-warning" title="Редактирай">
                                        <i class="bi bi-pencil-square fs-5"></i>
                                    </a>
                                    <form asp-action="Delete" asp-route-id="@car.Id" method="post"
                                          onsubmit="return confirm('Сигурни ли сте, че искате да изтриете @car.Brand?')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="border-0 bg-transparent text-danger p-0" title="Изтрий">
                                            <i class="bi bi-trash fs-5"></i>
                                        </button>
                                    </form>
                                </div>
                            }
                        </div>

                        <div class="d-flex gap-3 mb-3 text-white-50 small">
                            <span><i class="bi bi-calendar3 me-1"></i>@car.Year г.</span>
                            <span><i class="bi bi-gear-wide-connected me-1"></i>@(car.Transmission == "Automatic" ? "Автоматик" : "Ръчна")</span>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mt-4">
                            <div>
                                <span class="d-block text-white-50 small mb-0">Цена на ден</span>
                                <h4 class="text-turquoise fw-bold m-0">@car.PricePerDay лв.</h4>
                            </div>
                            <div class="d-flex gap-2">
                                <a asp-action="Details" asp-route-id="@car.Id" class="btn btn-outline-light btn-sm rounded-pill px-3">
                                    Детайли
                                </a>

                                @if (User.Identity.IsAuthenticated && car.IsAvailable && !User.IsInRole("Admin"))
                                {
                                    <a asp-controller="Rentals" asp-action="Create" asp-route-carId="@car.Id"
                                       class="btn btn-turquoise btn-sm rounded-pill px-3 fw-bold">
                                        Резервирай
                                    </a>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>