@model Rent_a_car.Models.Car

@{
    ViewData["Title"] = "Редакция на автомобил";
}

<div class="container" style="padding-top: 150px; padding-bottom: 60px;">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">

            <div class="text-center mb-5">
                <h1 class="heading-1" style="font-size: 2.5rem;">Редактиране</h1>
                <h2 class="heading-2" style="font-size: 1.2rem;">@Model.Brand @Model.Model</h2>
            </div>

            @if (!ViewData.ModelState.IsValid)
            {
                <div asp-validation-summary="All" class="text-danger small mb-4 p-3 rounded"
                     style="background: rgba(220, 53, 69, 0.1); border: 1px solid rgba(220, 53, 69, 0.2);">
                </div>
            }

            <div class="glass-card p-5 shadow-lg">
                <form asp-action="Edit" method="post">
                    @Html.AntiForgeryToken()

                    <input type="hidden" asp-for="Id" />

                    <div class="row g-4">
                        <div class="col-md-6">
                            <label asp-for="Brand" class="form-label small fw-bold text-white-50">Марка</label>
                            <input asp-for="Brand" class="form-control form-control-dark" placeholder="Peugeot" />
                            <span asp-validation-for="Brand" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Model" class="form-label small fw-bold text-white-50">Модел</label>
                            <input asp-for="Model" class="form-control form-control-dark" placeholder="408" />
                            <span asp-validation-for="Model" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Year" class="form-label small fw-bold text-white-50">Година</label>
                            <input asp-for="Year" class="form-control form-control-dark" />
                            <span asp-validation-for="Year" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Class" class="form-label small fw-bold text-white-50">Клас</label>
                            <input asp-for="Class" class="form-control form-control-dark" />
                            <span asp-validation-for="Class" class="text-danger small"></span>
                        </div>

                        <div class="col-md-12">
                            <label asp-for="Transmission" class="form-label small fw-bold text-white-50">Скоростна кутия</label>
                            <select asp-for="Transmission" class="form-select form-select-dark">
                                <option value="Automatic">Автоматична</option>
                                <option value="Manual">Ръчна</option>
                            </select>
                            <span asp-validation-for="Transmission" class="text-danger small"></span>
                        </div>

                        <div class="col-md-12">
                            <label asp-for="PricePerDay" class="form-label small fw-bold text-white-50">Цена на ден (лв.)</label>
                            <input asp-for="PricePerDay" class="form-control form-control-dark" />
                            <span asp-validation-for="PricePerDay" class="text-danger small"></span>
                        </div>

                        <div class="col-md-12">
                            <label asp-for="ImageUrl" class="form-label small fw-bold text-white-50">URL на снимка</label>
                            <input asp-for="ImageUrl" class="form-control form-control-dark" />
                            <span asp-validation-for="ImageUrl" class="text-danger small"></span>
                        </div>

                        <div class="col-12">
                            <div class="form-check form-switch p-3 rounded-3" style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.05);">
                                <input class="form-check-input ms-0 me-3" asp-for="IsAvailable" style="cursor: pointer;">
                                <label class="form-check-label text-white" asp-for="IsAvailable">Наличен за наемане</label>
                            </div>
                        </div>

                        <div class="col-12 d-grid gap-3 pt-3">
                            <button type="submit" class="btn-search-car py-3 shadow-lg">
                                <i class="bi bi-save me-2"></i> ЗАПАЗИ ПРОМЕНИТЕ
                            </button>
                            <a asp-action="Index" class="btn btn-outline-light rounded-pill py-2">
                                <i class="bi bi-arrow-left me-2"></i>Назад
                            </a>
                        </div>
                    </div>
                </form>
            </div>
        </div>  
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}