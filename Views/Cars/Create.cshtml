@model Rent_a_car.Models.Car

@{
    ViewData["Title"] = "Добави автомобил";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-lg border-0 rounded-4" style="background: rgba(255, 255, 255, 0.05); backdrop-filter: blur(10px); border: 1px solid rgba(45, 212, 191, 0.2);">
                <div class="card-header bg-transparent border-bottom border-secondary p-4 text-center">
                    <h2 class="mb-0 fw-bold"><i class="bi bi-plus-circle-fill me-2 text-turquoise"></i>Добави автомобил</h2>
                </div>

                <div class="card-body p-4">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Brand" class="form-label text-white-50 fw-bold">Марка</label>
                                <input asp-for="Brand" class="form-control" placeholder="напр. BMW" />
                                <span asp-validation-for="Brand" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="Model" class="form-label text-white-50 fw-bold">Модел</label>
                                <input asp-for="Model" class="form-control" placeholder="напр. X5" />
                                <span asp-validation-for="Model" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Year" class="form-label text-white-50 fw-bold">Година на производство</label>
                                <input asp-for="Year" type="number" class="form-control" placeholder="2024" />
                                <span asp-validation-for="Year" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Class" class="form-label text-white-50 fw-bold">Категория / Клас</label>
                                <input asp-for="Class" class="form-control" placeholder="напр. Джипове, Седан, Лукс..." />
                                <span asp-validation-for="Class" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="PricePerDay" class="form-label text-white-50 fw-bold">Цена на ден (лв.)</label>
                                <input asp-for="PricePerDay" class="form-control" placeholder="0.00" />
                                <span asp-validation-for="PricePerDay" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Transmission" class="form-label text-white-50 fw-bold">Скоростна кутия</label>
                                <select asp-for="Transmission" class="form-select border-turquoise">
                                    <option value="Automatic">Автоматична</option>
                                    <option value="Manual">Ръчна</option>
                                </select>
                                <span asp-validation-for="Transmission" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ImageUrl" class="form-label text-white-50 fw-bold">Линк към снимка (URL)</label>
                            <input asp-for="ImageUrl" class="form-control" placeholder="https://..." />
                            <span asp-validation-for="ImageUrl" class="text-danger small"></span>
                        </div>

                        <div class="form-check form-switch mb-4 mt-2">
                            <input asp-for="IsAvailable" class="form-check-input" type="checkbox" checked id="isAvailable" />
                            <label class="form-check-label text-white-50" for="isAvailable">Наличен за наемане</label>
                        </div>

                        <hr class="border-secondary mb-4" />

                        <div class="d-flex gap-3">
                            <button type="submit" class="btn btn-turquoise flex-grow-1 py-2 fw-bold shadow">
                                <i class="bi bi-save me-2"></i>ЗАПАЗИ АВТОМОБИЛА
                            </button>
                            <a asp-action="Index" class="btn btn-outline-light px-4 py-2">
                                ОТКАЗ
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}