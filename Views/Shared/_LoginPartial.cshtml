@using Microsoft.AspNetCore.Identity
@using Rent_a_car.Models @* Или където е твоят ApplicationUser *@
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<ul class="navbar-nav align-items-center">
    @if (SignInManager.IsSignedIn(User))
    {
        @* Извличаме името преди символа @ *@
        var userName = User.Identity?.Name?.Split('@')[0];

        <li class="nav-item d-flex align-items-center me-3">
            <div class="user-profile-pill d-flex align-items-center px-3 py-1 rounded-pill" style="background: rgba(255,255,255,0.05); border: 1px solid rgba(45, 212, 191, 0.2);">
                <i class="bi bi-person-circle text-turquoise me-2 fs-5"></i>
                <span class="text-white fw-bold">Здравей, @userName</span>
            </div>
        </li>

        <li class="nav-item">
            <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                <button type="submit" class="btn btn-logout rounded-pill px-4">
                    <i class="bi bi-box-arrow-right me-1"></i> Изход
                </button>
            </form>
        </li>
    }
    else
    {
        <li class="nav-item">
            <a class="nav-link px-3 text-white-50 hover-turquoise" asp-area="Identity" asp-page="/Account/Register">
                <i class="bi bi-person-plus me-1"></i> Регистрация
            </a>
        </li>
        <li class="nav-item ms-lg-2">
            <a class="btn btn-turquoise rounded-pill px-4 fw-bold shadow-sm" asp-area="Identity" asp-page="/Account/Login">
                <i class="bi bi-box-arrow-in-right me-1"></i> Вход
            </a>
        </li>
    }
</ul>