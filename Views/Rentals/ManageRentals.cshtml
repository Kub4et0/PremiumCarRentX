@model IEnumerable<Rent_a_car.Models.Rental>

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="fw-bold">Управление на заявки</h1>
        <span class="badge bg-turquoise p-2">Админ Панел</span>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success bg-dark text-turquoise border-turquoise rounded-pill text-center shadow-lg">
            @TempData["SuccessMessage"]
        </div>
    }

    <div class="card shadow-lg border-0 rounded-4 overflow-hidden" style="background: rgba(255, 255, 255, 0.05); backdrop-filter: blur(10px); border: 1px solid rgba(255,255,255,0.1);">
        <div class="table-responsive">
            <table class="table table-borderless align-middle mb-0 text-white">
                <thead style="background: rgba(45, 212, 191, 0.2);">
                    <tr>
                        <th class="py-3 ps-4">Клиент</th>
                        <th class="py-3">Автомобил</th>
                        <th class="py-3">Период</th>
                        <th class="py-3">Обща сума</th>
                        <th class="py-3">Статус</th>
                        <th class="py-3 text-center">Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr style="border-bottom: 1px solid rgba(255,255,255,0.05);">
                            <td class="py-3 ps-4">
                                <div class="fw-bold">@item.User?.Email</div>
                                <small class="text-white-50">ID: @item.Id</small>
                            </td>
                            <td class="py-3 text-turquoise fw-bold">@item.Car.Brand @item.Car.Model</td>
                            <td class="py-3 small">@item.StartDate.ToShortDateString() - @item.EndDate.ToShortDateString()</td>
                            <td class="py-3 fw-bold">@item.TotalPrice лв.</td>
                            <td class="py-3">
                                <span class="badge rounded-pill @(item.Status == "Confirmed" ? "bg-success" : item.Status == "Rejected" ? "bg-danger" : "bg-warning text-dark")">
                                    @item.Status
                                </span>
                            </td>
                            <td class="py-3 text-center">
                                @if (item.Status == "Pending")
                                {
                                    <div class="d-flex gap-2 justify-content-center">
                                        <form asp-action="ApproveRental" asp-route-id="@item.Id" method="post">
                                            <button type="submit" class="btn btn-sm btn-success rounded-pill px-3">Одобри</button>
                                        </form>
                                        <form asp-action="RejectRental" asp-route-id="@item.Id" method="post">
                                            <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3">Откажи</button>
                                        </form>
                                    </div>
                                }
                                else
                                {
                                    <i class="bi bi-check2-all text-white-50">Обработена</i>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>