@model Rent_a_car.Models.Rental
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    ViewData["Title"] = "Задаване на шофьор";
    var drivers = ViewBag.Drivers as List<SelectListItem>;
}

<h1>Задаване на шофьор</h1>

<form asp-action="AssignDriver" method="post">
    <input type="hidden" name="id" value="@Model.Id" />

    <div class="mb-3">
        <label class="form-label">Наем</label>
        <input class="form-control" value="№@Model.Id - @Model.Car?.Brand @Model.Car?.Model" readonly />
    </div>

    <div class="mb-3">
        <label class="form-label">Избери шофьор</label>
        <select name="driverId" class="form-select">
            <option value="">-- Избери шофьор --</option>
            @foreach (var driver in drivers)
            {
                <option value="@driver.Value">@driver.Text</option>
            }
        </select>
    </div>

    <button type="submit" class="btn btn-primary">Запази</button>
    <a asp-action="All" class="btn btn-secondary">Назад</a>
</form>