@model IEnumerable<Rent_a_car.Models.Rental>

@{
    ViewData["Title"] = "Моите резервации";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="fw-bold">Моите резервации</h1>
        <a asp-controller="Cars" asp-action="Index" class="btn btn-turquoise rounded-pill shadow-sm">
            <i class="bi bi-plus-lg me-1"></i>Нова резервация
        </a>
    </div>

    <div class="card shadow-lg border-0 rounded-4 overflow-hidden" style="background: rgba(255, 255, 255, 0.05); backdrop-filter: blur(10px); border: 1px solid rgba(255,255,255,0.1);">
        <div class="table-responsive">
            <table class="table table-borderless align-middle mb-0" style="color: #f1f5f9;">
                <thead style="background: rgba(45, 212, 191, 0.2); border-bottom: 2px solid rgba(45, 212, 191, 0.3);">
                    <tr>
                        <th class="py-3 ps-4">Автомобил</th>
                        <th class="py-3">Период</th>
                        <th class="py-3">Шофьор</th>
                        <th class="py-3">Цена</th>
                        <th class="py-3 text-center">Статус</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr style="border-bottom: 1px solid rgba(255,255,255,0.05); transition: background 0.3s;" onmouseover="this.style.background='rgba(255,255,255,0.03)'" onmouseout="this.style.background='transparent'">
                            <td class="py-3 ps-4 fw-bold text-turquoise">
                                @item.Car.Brand @item.Car.Model
                            </td>
                            <td class="py-3 text-white-50">
                                <i class="bi bi-calendar-event me-2"></i>@item.StartDate.ToString("dd.MM.yyyy") - @item.EndDate.ToString("dd.MM.yyyy")
                            </td>
                            <td class="py-3 text-white-50">
                                @(item.WithDriver? item.Driver?.FullName : "Без шофьор")
                            </td>
                            <td class="py-3 fw-bold text-white">
                                @item.TotalPrice.ToString("F2") лв.
                            </td>
                            <td class="py-3 text-center">
                                @{
                                    var statusClass = item.Status switch
                                    {
                                        "Pending" => "bg-warning text-dark",
                                        "Confirmed" => "bg-success text-white",
                                        "Cancelled" => "bg-danger text-white",
                                        "Completed" => "bg-info text-dark",
                                        _ => "bg-secondary text-white"
                                    };
                                }
                                <span class="badge rounded-pill px-3 py-2 @statusClass">@item.Status</span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center mt-5 p-5 card rounded-4 border-0" style="background: rgba(255,255,255,0.03);">
            <i class="bi bi-calendar-x fs-1 text-white-50 mb-3"></i>
            <h4 class="text-white-50">Все още нямате направени резервации.</h4>
            <div class="mt-3">
                <a asp-controller="Cars" asp-action="Index" class="btn btn-turquoise">Разгледай автомобили</a>
            </div>
        </div>
    }
</div>

<style>
    .table > :not(caption) > * > * {
        background-color: transparent !important;
        box-shadow: none !important;
    }
</style>